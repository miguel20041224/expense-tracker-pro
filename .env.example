# =============================================================================
# FINTRACK — variables de entorno (Vite)
# =============================================================================
# 1. Copia este archivo:  cp .env.example .env
# 2. Rellena con los valores de Firebase Console → Project settings → Your apps
# 3. Nunca subas .env al repositorio (.gitignore lo excluye)
#
# Nota: las claves web de Firebase (VITE_*) son públicas en el cliente.
# Aun así, usa .env local y restricciones en Firebase (dominios autorizados).
# =============================================================================

# Proyecto Firebase
VITE_FIREBASE_PROJECT_ID=your_project_id

# Configuración de la app web (Firebase SDK)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
